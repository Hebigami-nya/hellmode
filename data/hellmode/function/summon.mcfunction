execute if score #random random matches 0..999 run data merge entity @e[type=drowned,tag=!modified,limit=1]  {id:"minecraft:drowned",Tags:["modified","rotting_diver"],CustomName:"Rotting Diver",equipment:{mainhand:{id:"minecraft:trident",count:1}},attributes:[{id:"minecraft:follow_range",base:64}]}

