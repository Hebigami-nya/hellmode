# teleports old boss away
teleport @e[tag=boss,tag=to_remove] -100000 0 0

# Randomly distributes summoned monsters above ground
spreadplayers ~ ~ 80 120 false @e[tag=summoned]
# Cleanup after distribution
tag @e[tag=summoned] remove summoned 

# Announces a little later to have a new random number
schedule function hellmode:entity/announcement 30t append