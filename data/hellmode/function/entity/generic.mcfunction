execute if score #random random matches 500..999 run data merge entity @e[type=zombified_piglin,tag=!modified,limit=1] {id:"minecraft:zombified_piglin",Tags:["modified","sentry_swine"],CustomName:"Sentry Swine",equipment:{feet:{id:"minecraft:copper_boots",count:1,components:{"minecraft:custom_name":"Sentry Swine's Boots","minecraft:trim":{material:"minecraft:gold",pattern:"minecraft:tide"},"minecraft:enchantments":{"hellmode:plating":4,"hellmode:curse_of_slowness":2,"unbreaking":3}}},legs:{id:"minecraft:copper_leggings",count:1,components:{"minecraft:custom_name":"Sentry Swine's Leggings","minecraft:trim":{material:"minecraft:gold",pattern:"minecraft:tide"},"minecraft:enchantments":{"hellmode:plating":4,"hellmode:curse_of_slowness":2,"unbreaking":3}}},chest:{id:"minecraft:copper_chestplate",count:1,components:{"minecraft:custom_name":"Sentry Swine's Chestplate","minecraft:trim":{material:"minecraft:gold",pattern:"minecraft:tide"},"minecraft:enchantments":{"hellmode:plating":4,"hellmode:curse_of_slowness":2,"unbreaking":3}}},mainhand:{id:"minecraft:copper_axe",count:1,components:{"minecraft:custom_name":"Sentry Swine's Sword","minecraft:enchantments":{"hellmode:heavy_weapon":5,"unbreaking":3}}}},drop_chances:{feet:0.100,legs:0.100,chest:0.100,mainhand:0.100},attributes:[{id:"minecraft:attack_damage",base:10}]}

# Swinish Brute
# An empowered Piglin Brute that spawns with regular Piglins
execute if score #random random matches 0..199 at @e[type=piglin,tag=!modified,limit=1] run summon piglin_brute ~ ~ ~ {id:"minecraft:piglin_brute",Tags:["modified","swinish_brute"],CustomName:{"shadow_color":-5636096,"text":"Swinish Brute"},equipment:{mainhand:{id:"minecraft:netherite_axe",count:1,components:{"minecraft:custom_name":{"shadow_color":-5636096,"text":"Brute Swine's Sword"},"minecraft:enchantments":{"hellmode:heavy_weapon":5,"unbreaking":5}}}},drop_chances:{mainhand:0.100},attributes:[{id:"minecraft:armor",base:16},{id:"minecraft:armor_toughness",base:16},{id:"minecraft:attack_damage",base:12}]}

