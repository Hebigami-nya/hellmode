summon minecraft:evoker_fangs ~2 ~ ~2
summon minecraft:evoker_fangs ~ ~ ~3
summon minecraft:evoker_fangs ~-2 ~ ~2
summon minecraft:evoker_fangs ~-3 ~ ~
summon minecraft:evoker_fangs ~2 ~ ~-2
summon minecraft:evoker_fangs ~ ~ ~-3
summon minecraft:evoker_fangs ~-2 ~ ~-2